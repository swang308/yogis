# Copy to .env and fill with values from your Supabase project
# (Project Settings -> API). The PUBLIC_ prefix exposes them to the browser,
# which is correct for the URL and the anon key.

PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The "publishable" key (sb_publishable_...) from Project Settings -> API Keys.
# Safe in the browser; Row Level Security protects the data.
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only secrets (NEVER prefix with PUBLIC_, never commit real values).
# Used later by the Stripe webhook / server functions:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# STRIPE_SECRET_KEY=sk_live_...

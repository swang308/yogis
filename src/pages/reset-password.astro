---
import Base from '../layouts/Base.astro';
---

<Base title="Reset password — Yogis" description="Set a new password for your Yogis account.">
  <section class="section">
    <div class="container reset-wrap">
      <div class="card reset-card">
        <h1>Set a new password</h1>
        <p id="reset-hint" class="reset-hint">
          Use the link from your password-reset email to open this page.
        </p>
        <form id="form-reset" class="login-form">
          <label for="np">New password</label>
          <input id="np" type="password" autocomplete="new-password" placeholder="At least 8 characters" minlength="8" required />
          <button type="submit" class="btn btn-primary">Save new password</button>
        </form>
        <p id="reset-msg" class="auth-msg" hidden></p>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from '../lib/supabase.js';

    const msg = document.getElementById('reset-msg');
    function setMsg(text, kind) {
      msg.textContent = text;
      msg.className = `auth-msg ${kind}`;
      msg.hidden = false;
    }

    // The email link contains a recovery token; supabase-js picks it up
    // automatically and starts a temporary session.
    document.getElementById('form-reset').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!supabase) return setMsg('Accounts aren’t configured yet.', 'err');
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return setMsg('This page only works from the reset link in your email. Request a new link from the login page.', 'err');
      const { error } = await supabase.auth.updateUser({
        password: document.getElementById('np').value,
      });
      if (error) return setMsg(error.message, 'err');
      setMsg('Password updated — taking you to your account…', 'ok');
      setTimeout(() => { window.location.href = '/account'; }, 1200);
    });
  </script>
</Base>

<style>
  .reset-wrap { max-width: 480px; }

  .reset-card { padding: 2rem 2.5rem 2.2rem; }

  .reset-hint { color: var(--text-soft); font-size: 0.93rem; }

  .login-form { display: grid; gap: 0.4rem; }

  .login-form label { font-weight: 600; font-size: 0.92rem; }

  .login-form input {
    padding: 0.75rem 0.9rem;
    border: 1.5px solid var(--blue);
    border-radius: 10px;
    font-size: 1rem;
    font-family: var(--font-body);
    background: var(--white);
    color: var(--text);
    margin-bottom: 0.9rem;
  }

  .login-form input:focus {
    outline: none;
    border-color: var(--purple);
    box-shadow: 0 0 0 3px rgba(151, 143, 196, 0.25);
  }

  .auth-msg {
    margin: 1.2rem 0 0;
    padding: 0.8rem 1rem;
    border-radius: 10px;
    font-size: 0.93rem;
  }

  .auth-msg.ok { background: var(--blue); color: var(--text); }
  .auth-msg.err { background: #F3D9D9; color: #7A3B3B; }
  .auth-msg[hidden] { display: none; }
</style>
